{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "prefix": {
      "value": "AMRL"
    },

    "tags": {
      "value": {
        "environment": "lab"
      }
    },

    "regionIndexMap": {
      "value": {
        "southafricanorth": 1,
        "australiaeast": 2,
        "australiasoutheast": 3,
        "austriaeast": 4,
        "belgiumcentral": 5,
        "canadaeast": 6,
        "centralindia": 7,
        "chilecentral": 8,
        "denmarkeast": 9,
        "eastasia": 10,
        "indonesiacentral": 11,
        "israelcentral": 12,
        "japaneast": 13,
        "japanwest": 14,
        "koreacentral": 15,
        "koreasouth": 16,
        "malaysiawest": 17,
        "mexicocentral": 18,
        "newzealandnorth": 19,
        "polandcentral": 20,
        "southindia": 21,
        "southeastasia": 22,
        "spaincentral": 23,
        "swedencentral": 24,
        "uaenorth": 25,
        "westcentralus": 26,
        "westus2": 27,
        "westeurope": 28
      }
    },

    "subnetIndexMap": {
      "value": {
        "firewall": 0,
        "jumpbox": 1,
        "dc": 2,
        "server": 3,
        "client": 4
      }
    },

    "regionCount": {
      "value": 28
    },

    "maxVmsPerRegion": {
      "value": 2
    },

    "vmCounts": {
      "value": {
        "dc": 28,
        "jumpbox": 4,
        "windowsServer": 6,
        "windowsClient": 6,
        "linuxServer": 6,
        "linuxClient": 6
      }
    },

    "jumpboxAllowedSources": {
      "value": [
        "<your-public-ip>",
        "<your-public-cidr-range>"
      ]
    },

    "deploySubnets": {
      "value": true
    },

    "enableClientSsh": {
      "value": true
    },

    "windowsServerImage": {
      "value": {
        "publisher": "MicrosoftWindowsServer",
        "offer": "WindowsServer",
        "sku": "2022-datacenter-g2",
        "version": "latest"
      }
    },
    "windowsClientImage": {
      "value": {
        "publisher": "MicrosoftWindowsDesktop",
        "offer": "windows-10",
        "sku": "win10-22h2-ent-g2",
        "version": "latest"
      }
    },
    "ubuntuImage": {
      "value": {
        "publisher": "Canonical",
        "offer": "0001-com-ubuntu-server-jammy",
        "sku": "22_04-lts-gen2",
        "version": "latest"
      }
    },
    "vmSizes": {
      "value": {
        "dc": "<vm-size-for-dc>",
        "jumpbox": "<vm-size-for-jumpbox>",
        "windowsServer": "<vm-size-for-windows-server>",
        "windowsClient": "<vm-size-for-windows-client>",
        "linuxServer": "<vm-size-for-linux-server>",
        "linuxClient": "<vm-size-for-linux-client>"
      }
    },
    "osDisks": {
      "value": {
        "dc": {
          "storageAccountType": "<os-disk-sku-for-dc>",
          "diskSizeGB": 128
        },
        "jumpbox": {
          "storageAccountType": "<os-disk-sku-for-jumpbox>",
          "diskSizeGB": 64
        },
        "windowsServer": {
          "storageAccountType": "<os-disk-sku-for-windows-server>",
          "diskSizeGB": 128
        },
        "windowsClient": {
          "storageAccountType": "<os-disk-sku-for-windows-client>",
          "diskSizeGB": 64
        },
        "linuxServer": {
          "storageAccountType": "<os-disk-sku-for-linux-server>",
          "diskSizeGB": 128
        },
        "linuxClient": {
          "storageAccountType": "<os-disk-sku-for-linux-client>",
          "diskSizeGB": 64
        }
      }
    },
    "adminPublicKey": {
      "value": "ssh-ed25519 <public-key>"
    },
    "jumpboxAdminUsername": {
      "value": "azureadmin"
    },
    "jumpboxAdminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subscription-id>/resourceGroups/<foundation-rg>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
        },
        "secretName": "jumpboxAdminPassword"
      }
    },
    "serverAdminUsername": {
      "value": "azureadmin"
    },
    "serverAdminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subscription-id>/resourceGroups/<foundation-rg>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
        },
        "secretName": "serverAdminPassword"
      }
    },
    "clientAdminUsername": {
      "value": "azureadmin"
    },
    "clientAdminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subscription-id>/resourceGroups/<foundation-rg>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
        },
        "secretName": "clientAdminPassword"
      }
    }
  }
}
